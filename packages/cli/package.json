{
  "name": "@foundry/cli",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "foundry": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && mkdir -p dist/templates && cp -r src/templates/minimal src/templates/metrics-dashboard src/templates/service-catalog-entry src/templates/crud-admin dist/templates/",
    "dev": "tsx src/index.ts",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@foundry/agent-core": "workspace:*",
    "@foundry/compute-providers": "workspace:*",
    "@foundry/scanner-service": "workspace:*",
    "commander": "^13.0.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^3.0.0"
  }
}
